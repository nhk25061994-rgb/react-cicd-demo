pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: docker
    image: docker:27-cli
    command: ['cat']
    tty: true
    volumeMounts:
    - name: docker-sock
      mountPath: /var/run/docker.sock
  volumes:
  - name: docker-sock
    hostPath:
      path: /var/run/docker.sock
"""
        }
    }
    environment {
        IMAGE_REPO = "nhk519519/react-demo-app"
        IMAGE_TAG  = "v${env.BUILD_NUMBER}"
    }
    stages {
        stage("Checkout") {
            steps {
                checkout scm
                echo "Code checked out!"
            }
        }
        stage("Build Docker Image") {
            steps {
                container("docker") {
                    sh "docker build -t ${IMAGE_REPO}:${IMAGE_TAG} ./app"
                }
            }
        }
        stage("Push to DockerHub") {
            steps {
                container("docker") {
                    withCredentials([usernamePassword(credentialsId: "dockerhub-credentials", usernameVariable: "USER", passwordVariable: "PASS")]) {
                        sh "docker login -u $USER -p $PASS"
                        sh "docker push ${IMAGE_REPO}:${IMAGE_TAG}"
                    }
                }
            }
        }
        stage("Update GitOps") {
            steps {
                sh "sed -i 's|tag:.*|tag: ${IMAGE_TAG}|' helm/react-app/values.yaml"
                sh "git config user.email 'jenkins@ci.local'"
                sh "git config user.name 'Jenkins'"
                sh "git add helm/react-app/values.yaml"
                sh "git commit -m 'ci: update image to ${IMAGE_TAG}'"
                sh "git push origin main"
            }
        }
    }
    post {
        success { echo "Pipeline succeeded!" }
        failure { echo "Pipeline failed!" }
    }
}