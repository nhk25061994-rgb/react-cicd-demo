pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: docker
    image: docker:27-cli
    command: ['cat']
    tty: true
    volumeMounts:
    - name: docker-sock
      mountPath: /var/run/docker.sock
  volumes:
  - name: docker-sock
    hostPath:
      path: /var/run/docker.sock
"""
        }
    }
    environment {
        IMAGE_REPO = "nhk519519/react-demo-app"
        IMAGE_TAG  = "v${env.BUILD_NUMBER}"
    }
    stages {
        stage("Checkout") {
            steps {
                checkout scm
                echo "Code checked out!"
            }
        }
        stage("Build Docker Image") {
            steps {
                container("docker") {
                    sh "docker build -t ${IMAGE_REPO}:${IMAGE_TAG} ./app"
                }
            }
        }
        stage("Push to DockerHub") {
            steps {
                container("docker") {
                    withCredentials([usernamePassword(credentialsId: "dockerhub-credentials", usernameVariable: "USER", passwordVariable: "PASS")]) {
                        sh "docker login -u $USER -p $PASS"
                        sh "docker push ${IMAGE_REPO}:${IMAGE_TAG}"
                    }
                }
            }
        }
        stage("Update GitOps") {
            steps {
                withCredentials([sshUserPrivateKey(credentialsId: "github-ssh", keyFileVariable: "SSH_KEY")]) {
                    sh """
                        mkdir -p ~/.ssh
                        cp \$SSH_KEY ~/.ssh/id_ed25519
                        chmod 600 ~/.ssh/id_ed25519
                        ssh-keyscan github.com >> ~/.ssh/known_hosts
                        export GIT_SSH_COMMAND="ssh -i ~/.ssh/id_ed25519 -o StrictHostKeyChecking=no"
                        sed -i 's|tag:.*|tag: ${IMAGE_TAG}|' helm/react-app/values.yaml
                        git config user.email 'jenkins@ci.local'
                        git config user.name 'Jenkins'
                        git checkout -B main
                        git add helm/react-app/values.yaml
                        git commit -m 'ci: update image to ${IMAGE_TAG}'
                        git push origin HEAD:main
                    """
                }
            }
        }
    }
    post {
        success { echo "Pipeline succeeded! Image: ${IMAGE_REPO}:${IMAGE_TAG}" }
        failure { echo "Pipeline failed!" }
    }
}